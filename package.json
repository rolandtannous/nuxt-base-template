{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test:dev": "NUXT_VITEST_DEV_TEST=true nuxt dev --no-fork",
    "test:unit": "vitest",
    "test:types": "nuxi prepare && vue-tsc --noEmit",
    "test:happy-dom": "VITEST_DOM_ENV=happy-dom npm run test:unit -- --run",
    "test": "npm run test:happy-dom && npm run test:dev && npm run test:types",
    "lint": "eslint . --ext .vue,.ts,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore"
  },
  "devDependencies": {
    "@nuxt/devtools": "^0.8.3",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/eslint-module": "^4.1.0",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/vue": "^8.0.1",
    "@typescript-eslint/parser": "^6.12.0",
    "@vueuse/core": "^10.6.1",
    "@vueuse/nuxt": "^10.6.1",
    "@zadigetvoltaire/nuxt-gtm": "^0.0.13",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "happy-dom": "^12.10.3",
    "msw": "^2.0.8",
    "nuxt": "^3.9.0",
    "nuxt-icon": "^0.6.6",
    "nuxt-lodash": "^2.5.3",
    "nuxt-schema-org": "^3.2.1",
    "nuxt-vitest": "^0.11.5",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "typescript": "^5.2.2",
    "vitest": "^0.33.0",
    "vitest-environment-nuxt": "^0.11.5",
    "cypress":"^13.6.1",
    "vue": "^3.3.8",
    "vue-router": "^4.2.5",
    "vue-tsc": "^1.8.22"
  },
  "dependencies": {
    "@nuxt/ui": "^2.11.1",
    "@pinia/nuxt": "^0.5.1",
    "pinia": "^2.1.7"
  }
}
